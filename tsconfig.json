{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "composite": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "types": [
      "trusted-types"
    ],
    "paths": {
      "@/app/*": [
        "src/app/*"
      ],
      "@/features/*": [
        "src/features/*"
      ],
      "@/components/*": [
        "src/components/*"
      ],
      "@/hooks/*": [
        "src/hooks/*"
      ],
      "@kb/*": [
        "src/kb/*"
      ],
      "@/shared/*": [
        "src/shared/*"
      ],
      "@/blog.config": [
        "blog.config.ts"
      ],
      "@/server/*": [
        "src/server/*"
      ],
      "@/generated/*": [
        "src/generated/*"
      ],
      "#content": [
        "./.velite"
      ],
      "contentlayer/generated": [
        "./.contentlayer/generated"
      ],
      "pliny/*": [
        "node_modules/pliny/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "**/*.js",
    "**/*.json",
    "**/*.mjs",
    "**/*.ts",
    "**/*.tsx",
    ".contentlayer/generated",
    ".contentlayer/generated/**/*.json",
    ".next-dev/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    ".velite",
    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "eslint.config.mjs",
    "velite.config.ts",
    "edgeone"
  ]
}
