    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cn-fontsource-lxgw-wen-kai-gb-screen": "^1.0.6",
    "contentlayer2": "0.5.8",
