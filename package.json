{
  "name": "cot",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "prepare:generated-content": "tsx ./scripts/build/prepare-generated-content.ts",
    "prepare:kb-content": "velite && node scripts/fix-velite-types.js",
    "generate:kb-search": "node scripts/build-search-index.js",
    "prepare:kb-search": "pnpm generate:kb-search",
    "dev": "pnpm prepare:generated-content && pnpm prepare:kb-content && pnpm prepare:kb-search && concurrently \"velite --watch\" \"node scripts/build-search-index.js --watch\" \"cross-env NEXT_DIST_DIR=.next-dev next dev -H 127.0.0.1\"",
    "dev:clean": "pnpm dlx rimraf .next-dev .contentlayer .velite && pnpm prepare:generated-content && pnpm prepare:kb-content && pnpm prepare:kb-search && concurrently \"velite --watch\" \"node scripts/build-search-index.js --watch\" \"cross-env NEXT_DIST_DIR=.next-dev next dev -H 127.0.0.1\"",
    "start": "next start",
    "build": "pnpm prepare:generated-content && pnpm prepare:kb-content && pnpm prepare:kb-search && cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 next build && cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 tsx ./scripts/build/postbuild.ts && (pnpm seo:push || true)",
    "seo:push": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 tsx scripts/seo-push.ts",
    "serve": "next start",
    "analyze": "pnpm prepare:generated-content && pnpm prepare:kb-content && pnpm prepare:kb-search && cross-env ANALYZE=true next build",
    "lint": "eslint --fix src/app src/features src/kb src/shared src/server scripts --ext .js,.jsx,.ts,.tsx",
    "typecheck": "pnpm prepare:generated-content && pnpm prepare:kb-content && pnpm prepare:kb-search && contentlayer2 build && tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/bundle-analyzer": "15.5.12",
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cn-fontsource-lxgw-wen-kai-gb-screen": "^1.0.6",
    "contentlayer2": "0.5.8",
    "esbuild": "0.27.3",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.36.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "image-size": "2.0.2",
    "kbar": "0.1.0-beta.45",
    "lenis": "^1.3.23",
    "lucide-react": "^0.577.0",
    "misans": "^4.1.0",
    "next": "15.5.12",
    "next-contentlayer2": "0.5.8",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pliny": "0.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vaul": "^1.1.2",
    "velite": "^0.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@svgr/webpack": "^8.1.0",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-preset-minify": "7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "pnpm exec eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "pnpm exec prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "contentlayer2",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.28.0"
}
