{
  "name": "coet-blog",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "prepare:generated-content": "tsx ./scripts/build/prepare-generated-content.ts",
    "dev": "pnpm prepare:generated-content && next dev -H 127.0.0.1",
    "dev:clean": "pnpm dlx rimraf .next .contentlayer && pnpm prepare:generated-content && next dev -H 127.0.0.1",
    "start": "next start -p 1021",
    "build": "pnpm prepare:generated-content && cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 next build && cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 tsx ./scripts/build/postbuild.ts",
    "seo:push": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=1 tsx scripts/seo-push.ts",
    "serve": "next start -p 1021",
    "analyze": "pnpm prepare:generated-content && cross-env ANALYZE=true next build",
    "lint": "eslint --fix src/app src/features src/shared src/config src/server scripts --ext .js,.jsx,.ts,.tsx",
    "typecheck": "pnpm prepare:generated-content && contentlayer2 build && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "tsx scripts/seed-admin.ts",
    "db:seed-friends": "tsx scripts/seed-friends.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/fira-code": "^5.2.7",
